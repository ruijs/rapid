{
  "name": "root",
  "private": true,
  "scripts": {
    "build": "lerna run build",
    "dev": "pnpm --filter=rapid-example-remix dev",
    "start": "pnpm --filter=rapid-example-remix start",
    "gen-meta": "pnpm --filter=rapid-example-remix gen-meta",
    "update-rpd-models": "pnpm --filter=rapid-example-remix update-rpd-models",
    "sync-db-schema": "pnpm --filter=rapid-example-remix sync-db-schema",
    "test": "lerna run test",
    "fmt:code": "prettier . --write",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "husky": "^9.1.7",
    "lerna": "^5.5.4",
    "lint-staged": "^16.2.7",
    "prettier": "2.8.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
